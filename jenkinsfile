pipeline {
    agent any

    stages {
        stage('Build') {
            agent {
                docker {
                    image 'node:18'
                    reuseNode true
                }
            }
            steps {
                sh '''
                    ls -la
                    node --version
                    npm --version
                    npm ci
                    npm run build
                    ls -la
                '''
            }
        }

        stage('Test') {
            steps {
                sh '''
                    echo "Running tests..."

                    if [ -f /build/index.html]; then
                        echo "Build successful"
                    else
                        echo "Build failed"
                        exit 1
                    fi

                    npm test
                '''
            }
        }
    }
}